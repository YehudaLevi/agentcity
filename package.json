{
  "name": "agentcity",
  "version": "0.1.1",
  "description": "Your work builds a city. Your agent is the architect. A persistent, local-first pixel city compiled from your AI-coding-agent activity.",
  "license": "MIT",
  "author": "Yehuda Levi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YehudaLevi/agentcity.git"
  },
  "homepage": "https://github.com/YehudaLevi/agentcity#readme",
  "bugs": {
    "url": "https://github.com/YehudaLevi/agentcity/issues"
  },
  "keywords": [
    "ai-agents",
    "claude-code",
    "visualization",
    "pixel-art",
    "isometric",
    "city",
    "developer-tools",
    "local-first",
    "gamification"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "agentcity": "bin/agentcity.js"
  },
  "files": [
    "bin",
    "src",
    "dist",
    "web",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "prepare": "npm run build",
    "compile": "tsx src/cli-compile.ts",
    "dev": "node -e \"const{mkdtempSync}=require('node:fs');const{tmpdir}=require('node:os');const{join}=require('node:path');const{spawn}=require('node:child_process');const d=mkdtempSync(join(tmpdir(),'agentcity-dev-'));console.log('agentcity dev root:',d);spawn(process.execPath,[join('bin','agentcity.js'),'--root',d,'--history',join('test','fixtures','claude-history'),'--pixelagents',join('test','fixtures','pixelagents')],{stdio:'inherit'});\""
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
